# =========================
# DJANGO (LOCAL DEV)
# =========================

# DEBUG
# Active le mode debug Django (dev uniquement).
DEBUG=True

# SECRET_KEY
# Clé secrète Django utilisée pour la cryptographie interne.
# Ne jamais utiliser cette valeur en production.
SECRET_KEY=CHANGE_ME_SECRET_KEY

# ALLOWED_HOSTS
# Liste des hôtes autorisés (séparés par virgule).
ALLOWED_HOSTS=localhost,127.0.0.1


# =========================
# DATABASE (PostgreSQL local)
# =========================

# DB_NAME
# Nom de la base PostgreSQL locale.
DB_NAME=CHANGE_ME_DB_NAME

# DB_USER
# Utilisateur PostgreSQL.
DB_USER=CHANGE_ME_DB_USER

# DB_PASSWORD
# Mot de passe PostgreSQL.
DB_PASSWORD=CHANGE_ME_DB_PASSWORD

# DB_HOST
# Adresse du serveur PostgreSQL.
DB_HOST=localhost

# DB_PORT
# Port PostgreSQL (5432 par défaut).
DB_PORT=5432


# =========================
# EMAIL (DEV)
# =========================

# EMAIL_BACKEND
# En dev : afficher les emails dans la console.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend


# =========================
# SECURITY (DEV)
# =========================

# Force la redirection HTTP -> HTTPS
SECURE_SSL_REDIRECT=False

# Cookie session sécurisé
SESSION_COOKIE_SECURE=False

# Cookie CSRF sécurisé
CSRF_COOKIE_SECURE=False

# SameSite des cookies session / CSRF
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax

# En-têtes de sécurité HTTP
SECURE_CONTENT_TYPE_NOSNIFF=True
SECURE_REFERRER_POLICY=same-origin
SECURE_CROSS_ORIGIN_OPENER_POLICY=same-origin

# Politique HSTS (désactivée en dev)
SECURE_HSTS_SECONDS=0

# HSTS sous-domaines
SECURE_HSTS_INCLUDE_SUBDOMAINS=False

# HSTS preload
SECURE_HSTS_PRELOAD=False


# =========================
# JWT
# =========================

# Durée de vie access token (minutes)
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=30

# Durée de vie refresh token (jours)
JWT_REFRESH_TOKEN_LIFETIME_DAYS=1

# Outils de développement additionnels (laisser False hors dev)
ENABLE_DJANGO_EXTENSIONS=True
