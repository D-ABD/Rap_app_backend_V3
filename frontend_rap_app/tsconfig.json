{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["vitest", "node"],
    "jsx": "react-jsx",
    "strict": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "paths": {
      "src/*": ["./src/*"],
      "react-toastify": ["./node_modules/react-toastify/dist/index.d.ts"]
    }
  },
  "include": ["src"],
  "exclude": [
    "theme_backup",
    "src/theme_backup",
    "src/theme copy.ts",
    "src/theme_backup/theme copy.ts"
  ],
  "references": [{ "path": "./tsconfig.node.json" }]
}
